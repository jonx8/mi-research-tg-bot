# Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# Database
DB_NAME=database/participants.db

# Encryption Key 64 bytes (generate with: python -c "from src.utils.encryption import EncryptionService; print(EncryptionService.generate_key())")
ENCRYPTION_KEY=your_encryption_key_here

# Logging
LOG_LEVEL=INFO

# Google sheets export
GOOGLE_SHEETS_CREDENTIALS_PATH=config/mi-research-tg-bot.json
GOOGLE_SHEETS_SPREADSHEET_ID=your_google_spreadsheet_id
GOOGLE_SHEETS_EXPORT_INTERVAL=3600
GOOGLE_SHEETS_EXPORT_TIMEOUT=300

# Scheduler intervals (in seconds)
SURVEY_CHECK_INTERVAL=120
DAILY_LOG_CHECK_INTERVAL=120
INTERVENTION_CONTENT_INTERVAL=120

# Principal investigator contacts
PRINCIPAL_INVESTIGATOR_NAME="Иванов Иван Иванович"
PRINCIPAL_INVESTIGATOR_CONTACT="@investigator"